# Flask
FLASK_DEBUG=true

# Required for JSON summary generation (generate_json_from_combined.py)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Required for embeddings (add_embeddings.py and similarity search)
# Install Ollama (https://ollama.ai) and run: ollama pull nomic-embed-text

# Optional: for Datawrapper chart generation (graph_making.py)
# DATAWRAPPER_API_KEY=your-datawrapper-key

# Optional: referenced in metadata.yml for datasette-embeddings plugin
# OPENAI_KEY=your-openai-key
