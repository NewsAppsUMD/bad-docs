# Flask
FLASK_DEBUG=true

# Required for JSON summary generation and embeddings
# Install Ollama (https://ollama.ai) and run:
#   ollama pull qwen3.5:9b        (for JSON summaries)
#   ollama pull nomic-embed-text   (for embeddings/similarity search)

# Optional: for Datawrapper chart generation (graph_making.py)
# DATAWRAPPER_API_KEY=your-datawrapper-key

# Optional: referenced in metadata.yml for datasette-embeddings plugin
# OPENAI_KEY=your-openai-key
